{
  "name": "botnote-web",
  "private": true,
  "version": "4.5.6",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:api": "openapi-ts",
    "check:api": "node scripts/check-generated-api.mjs",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "pnpm typecheck && vite build && pnpm check:bundle",
    "check:bundle": "node scripts/check-bundle-budget.mjs",
    "test:e2e": "pnpm build && playwright test",
    "test:e2e:ci": "playwright test",
    "test": "vitest run --exclude 'e2e/**'",
    "typecheck": "tsc --noEmit -p tsconfig.app.json --pretty false && tsc --noEmit -p tsconfig.node.json --pretty false",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fullcalendar/react": "^7.0.1",
    "@tanstack/react-query": "^5.101.2",
    "clsx": "^2.1.1",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "temporal-polyfill": "^1.0.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "10.0.1",
    "@hey-api/openapi-ts": "0.99.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "axe-core": "^4.12.1",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "jsdom": "^29.1.1",
    "msw": "2.15.0",
    "prettier": "3.9.5",
    "typescript": "7.0.2",
    "typescript-eslint": "8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
