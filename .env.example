BOTNOTE_ENVIRONMENT=production
BOTNOTE_DATABASE_URL=postgresql+psycopg:///botnote
BOTNOTE_CREDENTIAL_KEY=replace-with-32-random-bytes-in-urlsafe-base64
# During rotation only: JSON or comma-separated previous 32-byte base64 keys, read-only.
BOTNOTE_CREDENTIAL_PREVIOUS_KEYS='[]'
BOTNOTE_TOKEN_PEPPER=replace-with-a-long-random-secret
# During rotation only: old peppers accepted until active sessions/tokens are migrated or revoked.
BOTNOTE_TOKEN_PREVIOUS_PEPPERS='[]'
BOTNOTE_PUBLIC_ORIGIN=https://imtegrale.example-tailnet.ts.net
BOTNOTE_ALLOWED_HOSTS='["imtegrale.example-tailnet.ts.net","192.168.50.5","localhost"]'
BOTNOTE_FRONTEND_DIST=/opt/botnote/current/frontend/dist
BOTNOTE_SECURE_COOKIES=true
BOTNOTE_ALLOW_IMT_SIGNUP=true
BOTNOTE_SESSION_TTL_DAYS=30
BOTNOTE_IMT_TIMEOUT_SECONDS=30
BOTNOTE_PASS_OPERATION_LEASE_SECONDS=180
BOTNOTE_PASS_QUIET_PERIOD_SECONDS=60
BOTNOTE_PASS_SESSION_MAX_DAYS=30
BOTNOTE_PASS_PROFILE_REFRESH_DAYS=30
BOTNOTE_PASS_HOURLY_QUOTA=3
BOTNOTE_PASS_DAILY_QUOTA=8
BOTNOTE_SCHEDULER_POLL_SECONDS=60
BOTNOTE_WORKER_HEARTBEAT_TTL_SECONDS=180
BOTNOTE_SYNC_LOCK_DIR=/run/botnote
BOTNOTE_TRUSTED_PROXY_IPS='["192.168.50.5"]'
BOTNOTE_ADMIN_ALLOWED_IDENTITIES='["tailnet:admin@example.com"]'
BOTNOTE_ADMIN_SESSION_TTL_HOURS=8
BOTNOTE_BACKEND_TLS_CERT=/etc/botnote/mtls/server.crt
BOTNOTE_BACKEND_TLS_KEY=/etc/botnote/mtls/server.key
BOTNOTE_BACKEND_TLS_CA=/etc/botnote/mtls/ca.crt
BOTNOTE_DATABASE_POOL_SIZE=10
BOTNOTE_DATABASE_MAX_OVERFLOW=10
BOTNOTE_DATABASE_POOL_TIMEOUT_SECONDS=10
# Parcours reste désactivé lorsque la racine de contenu n'est pas configurée.
# Cette racine privée ne doit jamais pointer vers frontend/public, frontend/dist ou app/static.
# Elle contient les sous-dossiers releases/ et le lien current géré atomiquement.
# BOTNOTE_LEARNING_CONTENT_ROOT=/opt/botnote-learning
# Une connexion par passkey exige une vérification IMT plus récente que cette durée.
BOTNOTE_LEARNING_STUDENT_STATUS_MAX_AGE_DAYS=30
# Le mode cohort conserve la politique FIP 2028 existante. Le mode personal est
# fail-closed et exige une release personal_library v3, exactement un login et
# les identités réseau privées ci-dessous.
BOTNOTE_LEARNING_ACCESS_MODE=cohort
BOTNOTE_LEARNING_AUDIENCE_ID=fip:2028
BOTNOTE_LEARNING_AUDIENCE_LABEL='FIP 2028'
BOTNOTE_LEARNING_LEVEL_LABEL=2A
BOTNOTE_LEARNING_ALLOWED_IMT_USERNAMES='[]'
BOTNOTE_LEARNING_ALLOWED_IDENTITIES='[]'
# Exemple générique de surcharge privée, à ne jamais recopier avec une identité réelle ici :
# BOTNOTE_LEARNING_ACCESS_MODE=personal
# BOTNOTE_LEARNING_AUDIENCE_ID=personal:owner
# BOTNOTE_LEARNING_ALLOWED_IMT_USERNAMES='["n00example"]'
# BOTNOTE_LEARNING_ALLOWED_IDENTITIES='["lan:192.0.2.10","tailnet:owner@example.invalid"]'
# Exception facultative pour l'unique compte propriétaire d'une instance privée.
# Le fichier doit rester hors dépôt, appartenir à l'utilisateur du service et être en 0400/0600.
# BOTNOTE_OWNER_IMT_USERNAME=n00example
# BOTNOTE_OWNER_IMT_PASSWORD_FILE=/etc/botnote/owner-imt-password
