BOTNOTE_ENVIRONMENT=production
BOTNOTE_DATABASE_URL=postgresql+psycopg:///botnote
BOTNOTE_CREDENTIAL_KEY=replace-with-32-random-bytes-in-urlsafe-base64
BOTNOTE_TOKEN_PEPPER=replace-with-a-long-random-secret
BOTNOTE_PUBLIC_ORIGIN=https://imtegrale.example-tailnet.ts.net
BOTNOTE_ALLOWED_HOSTS='["imtegrale.example-tailnet.ts.net","192.168.50.5","localhost"]'
BOTNOTE_FRONTEND_DIST=/opt/botnote/current/frontend/dist
BOTNOTE_SECURE_COOKIES=true
BOTNOTE_ALLOW_IMT_SIGNUP=true
BOTNOTE_SESSION_TTL_DAYS=30
BOTNOTE_IMT_TIMEOUT_SECONDS=30
BOTNOTE_PASS_OPERATION_LEASE_SECONDS=180
BOTNOTE_PASS_QUIET_PERIOD_SECONDS=60
BOTNOTE_PASS_SESSION_MAX_HOURS=24
BOTNOTE_PASS_PROFILE_REFRESH_DAYS=30
BOTNOTE_PASS_HOURLY_QUOTA=3
BOTNOTE_PASS_DAILY_QUOTA=8
BOTNOTE_SCHEDULER_POLL_SECONDS=60
BOTNOTE_SYNC_LOCK_DIR=/run/botnote
BOTNOTE_TRUSTED_PROXY_IPS='["192.168.50.5"]'
BOTNOTE_ADMIN_ALLOWED_IDENTITIES='["tailnet:admin@example.com"]'
BOTNOTE_ADMIN_SESSION_TTL_HOURS=8
BOTNOTE_BACKEND_TLS_CERT=/etc/botnote/mtls/server.crt
BOTNOTE_BACKEND_TLS_KEY=/etc/botnote/mtls/server.key
BOTNOTE_BACKEND_TLS_CA=/etc/botnote/mtls/ca.crt
BOTNOTE_DATABASE_POOL_SIZE=10
BOTNOTE_DATABASE_MAX_OVERFLOW=10
BOTNOTE_DATABASE_POOL_TIMEOUT_SECONDS=10
