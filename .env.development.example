# Développement local uniquement. Ne réutilisez jamais ces valeurs en production.
BOTNOTE_ENVIRONMENT=development
BOTNOTE_DATABASE_URL=sqlite+pysqlite:///./imtegrale-dev.sqlite3
BOTNOTE_CREDENTIAL_KEY=remplacer-par-une-cle-url-safe-de-32-octets
BOTNOTE_TOKEN_PEPPER=remplacer-par-un-secret-aleatoire-independant
BOTNOTE_PUBLIC_ORIGIN=http://127.0.0.1:5173
BOTNOTE_ALLOWED_HOSTS='["127.0.0.1","localhost"]'
BOTNOTE_TRUSTED_PROXY_IPS='["127.0.0.1"]'
BOTNOTE_SECURE_COOKIES=false
BOTNOTE_FRONTEND_DIST=frontend/dist
BOTNOTE_SYNC_LOCK_DIR=/tmp/imtegrale-sync
BOTNOTE_ADMIN_ALLOWED_IDENTITIES='["peer:127.0.0.1"]'
