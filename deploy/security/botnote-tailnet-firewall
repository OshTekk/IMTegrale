#!/bin/sh
set -eu

IPTABLES=/usr/sbin/iptables
IP6TABLES=/usr/sbin/ip6tables
TAILSCALE=/usr/bin/tailscale
CHAIN=BOTNOTE-TAILNET
LOCAL_CHAIN=BOTNOTE-LOCAL
NETWORK_ENV="${BOTNOTE_NETWORK_ENV:-/etc/default/botnote-network}"
[ -r "$NETWORK_ENV" ] || { printf 'missing %s\n' "$NETWORK_ENV" >&2; exit 1; }
# shellcheck disable=SC1090
. "$NETWORK_ENV"
: "${ADMIN_V4:?ADMIN_V4 is required}"
: "${ADMIN_V6:?ADMIN_V6 is required}"
: "${PVE_V4:?PVE_V4 is required}"
: "${PVE_V6:?PVE_V6 is required}"
: "${PVE_LAN_V4:?PVE_LAN_V4 is required}"
: "${LXC_LAN_V4:?LXC_LAN_V4 is required}"
: "${LAN_CIDR:?LAN_CIDR is required}"
: "${LAN_INTERFACE:?LAN_INTERFACE is required}"

TAILNET_V4_CIDR=100.64.0.0/10

ensure_jump() {
    command="$1"
    "$command" -t raw -N "$CHAIN" 2>/dev/null || true
    "$command" -t raw -F "$CHAIN"
    "$command" -t raw -C PREROUTING -i tailscale0 -j "$CHAIN" 2>/dev/null ||
        "$command" -t raw -I PREROUTING 1 -i tailscale0 -j "$CHAIN"
}

ensure_local_jump() {
    command="$1"
    "$command" -t filter -N "$LOCAL_CHAIN" 2>/dev/null || true
    "$command" -t filter -F "$LOCAL_CHAIN"
    "$command" -t filter -C OUTPUT -o lo -j "$LOCAL_CHAIN" 2>/dev/null ||
        "$command" -t filter -I OUTPUT 1 -o lo -j "$LOCAL_CHAIN"
    "$command" -t filter -A "$LOCAL_CHAIN" -p tcp --dport 18080 \
        -m owner --uid-owner 0 -j RETURN
    "$command" -t filter -A "$LOCAL_CHAIN" -p tcp --dport 18080 -j REJECT
    "$command" -t filter -A "$LOCAL_CHAIN" -j RETURN
}

add_rules() {
    # A source-scoped SNAT avoids Tailscale's mark matching twice across vmbr0.
    "$TAILSCALE" set --snat-subnet-routes=false
    "$IPTABLES" -t nat -C POSTROUTING \
        -s "$TAILNET_V4_CIDR" -d "$LAN_CIDR" -o "$LAN_INTERFACE" \
        -m comment --comment botnote-tailnet-lan-snat \
        -j SNAT --to-source "$PVE_LAN_V4" 2>/dev/null ||
        "$IPTABLES" -t nat -I POSTROUTING 1 \
            -s "$TAILNET_V4_CIDR" -d "$LAN_CIDR" -o "$LAN_INTERFACE" \
            -m comment --comment botnote-tailnet-lan-snat \
            -j SNAT --to-source "$PVE_LAN_V4"

    ensure_jump "$IPTABLES"
    "$IPTABLES" -t raw -A "$CHAIN" -d "$LXC_LAN_V4"/32 \
        -p tcp -m multiport --dports 8080,8443 -j DROP
    "$IPTABLES" -t raw -A "$CHAIN" -d "$LXC_LAN_V4"/32 -s "$ADMIN_V4"/32 \
        -p tcp --dport 22 -j ACCEPT
    "$IPTABLES" -t raw -A "$CHAIN" -d "$LXC_LAN_V4"/32 \
        -p tcp --dport 22 -j DROP
    "$IPTABLES" -t raw -A "$CHAIN" -d "$PVE_V4"/32 -s "$ADMIN_V4"/32 \
        -p tcp -m multiport --dports 22,3128,8006 -j ACCEPT
    "$IPTABLES" -t raw -A "$CHAIN" -d "$PVE_V4"/32 \
        -p tcp -m multiport --dports 22,3128,8006 -j DROP
    "$IPTABLES" -t raw -A "$CHAIN" -d "$PVE_LAN_V4"/32 -s "$ADMIN_V4"/32 \
        -p tcp -m multiport --dports 22,3128,8006 -j ACCEPT
    "$IPTABLES" -t raw -A "$CHAIN" -d "$PVE_LAN_V4"/32 \
        -p tcp -m multiport --dports 22,3128,8006 -j DROP

    ensure_jump "$IP6TABLES"
    "$IP6TABLES" -t raw -A "$CHAIN" -d "$PVE_V6"/128 -s "$ADMIN_V6"/128 \
        -p tcp -m multiport --dports 22,3128,8006 -j ACCEPT
    "$IP6TABLES" -t raw -A "$CHAIN" -d "$PVE_V6"/128 \
        -p tcp -m multiport --dports 22,3128,8006 -j DROP

    # Only tailscaled/root may reach the identity-bearing local reverse-proxy listener.
    ensure_local_jump "$IPTABLES"
    ensure_local_jump "$IP6TABLES"
}

remove_jump() {
    command="$1"
    while "$command" -t raw -C PREROUTING -i tailscale0 -j "$CHAIN" 2>/dev/null; do
        "$command" -t raw -D PREROUTING -i tailscale0 -j "$CHAIN"
    done
    "$command" -t raw -F "$CHAIN" 2>/dev/null || true
    "$command" -t raw -X "$CHAIN" 2>/dev/null || true
}

remove_local_jump() {
    command="$1"
    while "$command" -t filter -C OUTPUT -o lo -j "$LOCAL_CHAIN" 2>/dev/null; do
        "$command" -t filter -D OUTPUT -o lo -j "$LOCAL_CHAIN"
    done
    "$command" -t filter -F "$LOCAL_CHAIN" 2>/dev/null || true
    "$command" -t filter -X "$LOCAL_CHAIN" 2>/dev/null || true
}

remove_rules() {
    while "$IPTABLES" -t nat -C POSTROUTING \
        -s "$TAILNET_V4_CIDR" -d "$LAN_CIDR" -o "$LAN_INTERFACE" \
        -m comment --comment botnote-tailnet-lan-snat \
        -j SNAT --to-source "$PVE_LAN_V4" 2>/dev/null; do
        "$IPTABLES" -t nat -D POSTROUTING \
            -s "$TAILNET_V4_CIDR" -d "$LAN_CIDR" -o "$LAN_INTERFACE" \
            -m comment --comment botnote-tailnet-lan-snat \
            -j SNAT --to-source "$PVE_LAN_V4"
    done
    remove_jump "$IPTABLES"
    remove_jump "$IP6TABLES"
    remove_local_jump "$IPTABLES"
    remove_local_jump "$IP6TABLES"
}

case "${1:-apply}" in
    apply) add_rules ;;
    remove) remove_rules ;;
    *)
        printf 'usage: %s {apply|remove}\n' "$0" >&2
        exit 2
        ;;
esac
