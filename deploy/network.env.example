# Copy to /etc/default/botnote-network on the PVE and adapt every value.
# The addresses below document an example topology and are not production defaults.
PUBLIC_HOSTNAME=imtegrale.example-tailnet.ts.net
PVE_LAN_V4=192.168.50.5
LXC_LAN_V4=192.168.50.18
LAN_CIDR=192.168.50.0/24
LAN_GATEWAY_V4=192.168.50.1
LAN_INTERFACE=vmbr0
ADMIN_V4=100.64.0.100
ADMIN_V6=fd7a:115c:a1e0::100
PVE_V4=100.64.0.5
PVE_V6=fd7a:115c:a1e0::5
